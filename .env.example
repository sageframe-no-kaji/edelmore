# Edelmore Diary — environment variable template
#
#   cp .env.example .env
#   npm run dev
#
# Only DATABASE_URL is required. The transcription (Whisper) and narration
# (Kokoro TTS) services are optional, external homelab services — leave their
# URLs blank and the diary still works fully for typing and reading; only the
# voice features go quiet.
#
# There are no PIN or session-secret variables: users are created the first
# time you visit /admin on a fresh database, and sessions are random tokens
# stored in the sessions table. Reset a PIN by visiting /settings (or editing
# the SQLite file directly).


# ─── Database (required) ─────────────────────────────────────────────────────
# Local dev: relative path from repo root.
# Docker prod: overridden to /data/edelmore.db via container env.
DATABASE_URL=data/edelmore.db


# ─── Transcription / Whisper (optional) ──────────────────────────────────────
# Upstream WhisperX /asr endpoint. Leave blank to disable the mic button.
TRANSCRIPTION_URL=http://shingan.lan:9000/asr
# Optional bearer token sent to the upstream, if it requires one.
TRANSCRIPTION_API_KEY=


# ─── Narration / Kokoro TTS (optional) ───────────────────────────────────────
# Read-aloud service. Leave TTS_URL blank to disable read-aloud (the settings
# voice picker then falls back to the browser's built-in voices).
TTS_URL=http://shingan.lan:8880/dev/captioned_speech
TTS_VOICES_URL=http://shingan.lan:8880/v1/audio/voices
# Optional bearer token for the TTS upstream.
TTS_API_KEY=

# On-demand Kokoro lifecycle (optional). When DOCKER_API_URL and
# KOKORO_CONTAINER_NAME are set, the /api/speak shim starts the container on
# the first narration and stops it after KOKORO_IDLE_MINUTES of silence to free
# the GPU. Leave DOCKER_API_URL blank to assume Kokoro is always running.
DOCKER_API_URL=http://192.168.1.22:2376
KOKORO_CONTAINER_NAME=svc-kokoro
KOKORO_IDLE_MINUTES=10
