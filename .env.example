# Edelmore Diary — environment variable template
#
#   cp .env.example .env
#   # Generate SESSION_SECRET: openssl rand -hex 32
#   npm run dev


# ─── Database ───────────────────────────────────────────────────────────────
# Local dev: relative path from repo root.
# Docker prod: overridden to /data/edelmore.db via container env.
DATABASE_URL=data/edelmore.db


# ─── Session signing ────────────────────────────────────────────────────────
# Signs session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=


# ─── Initial PINs ───────────────────────────────────────────────────────────
# Seeded on first start when the users table is empty. Inert after that.
# Reset a PIN via the SQLite file or by rebuilding the DB. Must be 4 digits.
IONA_PIN=1111
ISLA_PIN=2222


# ─── Transcription ──────────────────────────────────────────────────────────
# Whisper /asr endpoint — shingan's whisperx-asr-service on the LAN.
TRANSCRIPTION_URL=http://shingan:9000/asr


# ─── Kokoro TTS ─────────────────────────────────────────────────────────────
# Narration service on shingan. The shim starts the container on demand
# (via DOCKER_API_URL) and stops it after KOKORO_IDLE_MINUTES of silence.
TTS_URL=http://shingan.lan:8880/dev/captioned_speech
TTS_VOICES_URL=http://shingan.lan:8880/v1/audio/voices

# Docker remote API for on-demand Kokoro startup/shutdown.
DOCKER_API_URL=http://192.168.1.22:2376
KOKORO_CONTAINER_NAME=svc-kokoro
KOKORO_IDLE_MINUTES=10
